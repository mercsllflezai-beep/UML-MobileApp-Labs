@startuml object-diagram

skinparam backgroundColor White
skinparam object {
  BackgroundColor White
  BorderColor Black
  ArrowColor Black
}

title "Диаграмма объектов: HelpHub"

object "guest1: Guest" as guest1 {
  sessionId: "sess_abc123"
  ip: "192.168.1.100"
}

object "user1: RegisteredUser" as user1 {
  id: 101
  name: "Вадим Чернов"
  email: "airogoff@yandex.ru"
  isVerified: true
}

object "psych1: Psychologist" as psych1 {
  id: 42
  license: "PSY-2025-001"
  specialization: ["Тревожность", "Депрессия"]
  rating: 4.8
  isAvailable: true
}

object "admin1: Administrator" as admin1 {
  id: 1
  username: "admin"
  permissions: ["full_access"]
}

object "profile1: Profile" as profile1 {
  userId: 101
  name: "Вадим Чернов"
  email: "airogoff@yandex.ru"
  registrationDate: "2025-01-01"
  bio: "Студент КНИТУ-КАИ"
}

object "progress1: UserProgress" as progress1 {
  id: 501
  completedAt: "2025-01-15 14:30"
  score: 85
  sessionCount: 12
}

object "session1: Session" as session1 {
  id: 1001
  startTime: "2025-01-15 14:00"
  endTime: "2025-01-15 15:00"
  status: "ACTIVE"
  type: "VIDEO"
}

object "community1: Community" as community1 {
  id: 5
  name: "Тревожность и стресс"
  description: "Поддержка при тревожных расстройствах"
  isPrivate: false
  memberCount: 245
}

object "event1: Event" as event1 {
  id: 20
  title: "Групповая терапия"
  dateTime: "2025-01-20 18:00"
  location: "Online (Zoom)"
  maxParticipants: 15
}

object "message1: Message" as message1 {
  id: 9001
  content: "Здравствуйте, нужна помощь..."
  timestamp: "2025-01-15 14:05"
  isAnonymous: true
}

' Связи
user1 --> profile1 : имеет
user1 --> progress1 : владеет
progress1 --> session1 : относится к
session1 --> psych1 : проводится
session1 --> user1 : запрашивается
user1 --> community1 : участник
community1 --> event1 : содержит
message1 --> session1 : принадлежит
admin1 --> user1 : управляет
guest1 ..> user1 : создаёт (register)

@enduml
